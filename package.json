{
	"name": "gateway-api-visualizer",
	"private": true,
	"version": "0.2.0",
	"description": "Visualize Kubernetes Gateway API resource coverage (Gateways -> Routes) from local YAML.",
	"type": "module",
	"packageManager": "pnpm@9.0.0",
	"scripts": {
		"dev": "vite",
		"build": "vite build && ./scripts/post-build.sh",
		"deploy": "vite build && ./scripts/post-build.sh",
		"preview": "vite preview",
		"lint": "oxlint src/ --tsconfig tsconfig.json",
		"typecheck": "tsgo --project tsconfig.json --noEmit",
		"format": "prettier --write .",
		"test": "vitest --run"
	},
	"dependencies": {
		"cytoscape": "^3.33.1",
		"js-yaml": "^4.2.0",
		"monaco-editor-core": "^0.55.1",
		"monaco-yaml": "^5.4.0",
		"svelte": "^5.56.1",
		"yaml-lint": "^1.7.0"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.5.2",
		"@typescript/native-preview": "7.0.0-dev.20260501.1",
		"autoprefixer": "^10.4.27",
		"oxlint": "^1.68.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"vitest": "^4.1.0"
	}
}
